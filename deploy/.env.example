# Copy to deploy/.env and fill in. Used by deploy/compose.yml.

# Public domain Traefik routes to (the Host rule). e.g. coglionazzi.com
APP_HOST=coglionazzi.com

# Public origin of the app. Baked into the client bundle at BUILD time AND
# used by better-auth (baseURL / trustedOrigins), so it must match the URL
# users actually hit — normally https://$APP_HOST.
VITE_FRONTEND_URL=https://coglionazzi.com

# Password for the bundled Postgres (user + db are both "coglionazzi").
POSTGRES_PASSWORD=change-me

# better-auth secret — generate one, e.g. `openssl rand -base64 32`.
AUTH_SECRET=change-me-to-a-long-random-string

# Discord OAuth (OPTIONAL — leave unset to disable the "Sign in with Discord"
# button). Both must be set for the provider to register. Register this redirect
# URL in the Discord app: $VITE_FRONTEND_URL/api/auth/callback/discord
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
