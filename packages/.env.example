# Copy to .env and adjust. Loaded by `dotenv -e ../.env` in app scripts
# (envDir: ".." in vite.config.ts picks it up for VITE_* too).
DATABASE_URL=postgres://user:password@localhost:5460/coglionazzi
AUTH_SECRET=change-me-to-a-long-random-string
VITE_FRONTEND_URL=http://localhost:3300
IMAGES_PATH=./data/images

# Discord OAuth (optional — login/signup with Discord). Create an app at
# https://discord.com/developers/applications, add a redirect of
# `${VITE_FRONTEND_URL}/api/auth/callback/discord`, and copy its OAuth2 creds.
# Leave blank to disable the Discord button. Secrets — no VITE_ prefix.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
