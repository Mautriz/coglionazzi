{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["VITE_FRONTEND_URL", "ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["VITE_FRONTEND_URL", "ENV"],
      "outputs": [".output/**", "dist/**"]
    },
    "dev": {
      "env": ["VITE_FRONTEND_URL", "ENV"],
      "persistent": true,
      "cache": false
    },
    "type-check": {
      "dependsOn": ["^type-check"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    }
  }
}
